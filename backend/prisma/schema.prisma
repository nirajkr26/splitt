generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

enum ExpenseStatus {
  ACTIVE
  FLAGGED
  REJECTED
}

enum IssueStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
}

model User {
  id      String  @id @default(cuid())
  clerkId String  @unique
  email   String  @unique
  name    String?

  groups         Group[]
  importSessions ImportSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id   String @id @default(cuid())
  name String

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  participants Participant[]
  expenses     Expense[]
  settlements  Settlement[]
  imports      ImportSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Participant {
  id String @id @default(cuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name String

  canonicalName String?

  joinedAt DateTime?
  leftAt   DateTime?

  aliases ParticipantAlias[]

  expenseShares ExpenseShare[]
  paidExpenses  Expense[]

  sentSettlements     Settlement[] @relation("SettlementFrom")
  receivedSettlements Settlement[] @relation("SettlementTo")

  createdAt DateTime @default(now())

  @@index([groupId])
}

model ParticipantAlias {
  id String @id @default(cuid())

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  alias String

  createdAt DateTime @default(now())

  @@unique([participantId, alias])
  @@index([alias])
}

model Expense {
  id String @id @default(cuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  description String

  amount Decimal @db.Decimal(12, 2)

  currency String @default("INR")

  expenseDate DateTime

  splitType SplitType

  paidById String
  paidBy   Participant @relation(fields: [paidById], references: [id])

  status ExpenseStatus @default(ACTIVE)

  shares ExpenseShare[]

  importSessionId String?
  importSession   ImportSession? @relation(fields: [importSessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([expenseDate])
}

model ExpenseShare {
  id String @id @default(cuid())

  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])

  amountOwed Decimal @db.Decimal(12, 2)

  percentage Decimal? @db.Decimal(5, 2)

  shares Int?

  createdAt DateTime @default(now())

  @@index([expenseId])
  @@index([participantId])
}

model Settlement {
  id String @id @default(cuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  fromId String
  from   Participant @relation("SettlementFrom", fields: [fromId], references: [id])

  toId String
  to   Participant @relation("SettlementTo", fields: [toId], references: [id])

  amount Decimal @db.Decimal(12, 2)

  settlementDate DateTime

  notes String?

  importSessionId String?
  importSession   ImportSession? @relation(fields: [importSessionId], references: [id])

  createdAt DateTime @default(now())

  @@index([groupId])
}

model ImportSession {
  id String @id @default(cuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  fileName String

  importedById String
  importedBy   User   @relation(fields: [importedById], references: [id])

  expenses    Expense[]
  settlements Settlement[]
  issues      ImportIssue[]

  createdAt DateTime @default(now())

  @@index([groupId])
}

model ImportIssue {
  id String @id @default(cuid())

  importSessionId String
  importSession   ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)

  rowNumber Int?

  issueType String

  description String

  severity IssueSeverity

  actionTaken String?

  status IssueStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@index([importSessionId])
}
